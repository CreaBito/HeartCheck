from PyQt5.QtCore import Qt
from PyQt5.QtWidgets import (
    QApplication, QWidget, QLineEdit, QPushButton, QHBoxLayout, QVBoxLayout, QLabel, QLineEdit)

from instr import *
from final_win import *


class MainWin(QWidget):
    def next_click():
        self.hide()
        self.fw = FinalWin()
    def __init__(self):
        super().__init__()
        self.set_appear()
        self.initUI()
        self.connects()
        self.show()

    def set_appear():
        self.setWindow(txt_title)
        self.resize(win_width, win_height)
        self.move(win_x,win_y)

    def initUI():
        self.h_line = QHBoxLayout
        self.r_line = QVDoxLayout
        self.l_line = QVBoxLayout

        self.btn_next = QPushButton(txt_sendresults, self)
        self.btn_test1 = QPushButton(txt_hinttest1, self)
        self.btn_test2 = QPushButton(txt_hinttest2, self)
        self.btn_test3 = QPushButton(txt_hinttest3, self)

        self.txt_test1 = QLabel(txt_test1)
        self.txt_test2 = QLabel(txt_test2)
        self.txt_test3 = QLabel(txt_test3)
        self.txt_age = QLabel(txt_age)
        self.txt_timer = QLabel(txt_timer)
        self.txt_name = QLabel(txt_name)

        self.txt_hinttest1 = QLineEdit(txt_hinttest1)
        self.txt_hinttest2 = QLineEdit(txt_hinttest2)
        self.txt_hinttest3 = QLineEdit(txt_hinttest3)
        self.txt_hintname = QLineEdit(txt_hintname)
        self.txt_hintage =  QLineEdit(txt_hintage)

        self.l_line.addWidget(self.txt_name,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_hintname,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_age,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_hintage,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_test1,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_starttest1,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_hinttest1,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_test2,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_starttest2,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_test3,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_starttest3,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_hinttest2,alignment = Qt.AlignCenter)
        self.l_line.addWidget(self.txt_starttest3,alignment = Qt.AlignCenter)

        self.r_line.addWidget(self.txt_timer,alignment = Qt.AlignCenter)

        self.h_line.addWidget(self.txt_sendresults,alignment = Qt.AlignCenter)

        self.h_line.addLayout(self.l_line)
        self.h_line.addLayout(self.r_line)

        main.setLayout(self.h_line)

    def connects():
        self.btn_next.clicked.connect(self.next_click)
